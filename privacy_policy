p{margin-bottom:14px;color:#333;font-size:15px}
ul{margin:12px 0 14px 20px;display:flex;flex-direction:column;gap:8px}
li{font-size:15px;color:#333}
strong{color:var(--gd)}
.highlight{background:var(--gl);border-left:3px solid var(--gm);border-radius:0 10px 10px 0;padding:16px 20px;margin:0 0 20px}
.highlight p{margin:0;font-size:14px;color:var(--gd)}
footer{background:var(--gd);padding:32px 5%;text-align:center}
